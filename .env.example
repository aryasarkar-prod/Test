# Port the Express server listens on. Defaults to 3000 when unset.
PORT=3000

# Set MOCK_MODE=true to force the backend to use the bundled mock data
# instead of calling the Open-Meteo APIs. Useful for offline demos and
# environments without external network access.
#
# Note: even when MOCK_MODE is unset/false, the backend will automatically
# fall back to the bundled mock data if an upstream Open-Meteo request
# fails or hangs longer than WEATHER_FETCH_TIMEOUT_MS (the response will
# be tagged with source: "mock-fallback").
MOCK_MODE=false

# Per-request timeout (in milliseconds) for the live Open-Meteo calls.
# If a fetch does not complete within this many ms it is aborted and the
# backend serves the bundled mock data instead. Defaults to 5000 when
# unset; only positive integers are honored.
WEATHER_FETCH_TIMEOUT_MS=5000
